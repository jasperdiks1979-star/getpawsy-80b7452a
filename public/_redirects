# GetPawsy 301 Redirects — Single-hop, no chains
# ═══════════════════════════════════════════════════════════════

# ── Canonical product URL redirect (singular → plural) ──
/product/:slug /products/:slug 301

# ── Legacy Pinterest landing pages → canonical PDP (singular slug → /products/:slug) ──
# All historical /lp/:slug Pinterest destinations resolve to live products that
# share the same slug. Query strings (UTMs) are preserved by the platform.
/lp/:slug /products/:slug 301

# ── Pinterest URL Recovery — legacy paths funnel through resolver ──
# Sends every historical Pinterest destination through the recovery engine,
# which 308-redirects to the live canonical PDP (or /collections/all as a
# final soft fallback). UTM and tracking query strings are preserved.
/go/*           https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-redirect?url=/go/:splat        302
/legacy/*       https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-redirect?url=/legacy/:splat    302
/old-product/*  https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-redirect?url=/old-product/:splat 302
/redirect/*     https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-redirect?url=/redirect/:splat   302

# ── Pinterest catalog feed ──
# Lovable static hosting does not proxy (status 200) to external hosts,
# so we 302-redirect to the edge function. Pinterest's catalog crawler
# follows 30x redirects, and the final response is valid RSS/XML.
/pinterest-feed.xml https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-feed?format=xml 302
/pinterest-feed     https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/pinterest-feed?format=xml 302

# ── Google Merchant Center feed (Task C: full live catalog) ──
# Public read-only URLs served by the merchant-feed-full edge function.
# Content-Type: text/tab-separated-values (TSV) or text/csv (CSV).
/feeds/google-merchant.tsv     https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/merchant-feed-full?file=tsv 302
/feeds/google-merchant.csv     https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/merchant-feed-full?file=csv 302
/feeds/google-merchant-audit.csv   https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/merchant-feed-full?file=audit 302
/feeds/google-merchant-summary.md  https://nojvgfbcjgipjxpfatmm.supabase.co/functions/v1/merchant-feed-full?file=summary 302

