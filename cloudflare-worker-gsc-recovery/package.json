{
  "name": "getpawsy-gsc-recovery",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker that emits real 410/301 status codes for the GSC 2026-07-19 soft-404 cohort on getpawsy.pet.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "verify": "bash test/smoke-test.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/worker.ts --bundle --format=esm --platform=neutral --loader:.json=json --outfile=dist/worker.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0",
    "vitest": "^2.1.9",
    "esbuild": "^0.24.0"
  }
}